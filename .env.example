# Counter-Strike 2 Server Configuration
STEAM_GAMESERVER_API=put_your_token_here
STARTUP_MAP=de_dust2

# System Resource & Permissions
# oracle cloud has four cores, i use 3
CPU_CORE_COUNT=3
# Process priority (niceness). -20 is highest priority, 19 is lowest.
# lower is better
SERVER_NICENESS=-10
PUID=1001
PGID=1001

# Modding & Updates
ALWAYS_UPDATE_ON_START=true
ENABLE_MODDING=false

# Override Mod Versions (Leave blank to always download the latest available release)
# Example CSS_URL: https://github.com/roflmuffin/CounterStrikeSharp/releases/download/v1.0.359/counterstrikesharp-with-runtime-linux-1.0.359.zip
MMS_URL=
CSS_URL=
